# ─── DocSense Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://docsense:docsense@localhost:5432/docsense

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=supersecretkey123

# Groq API Key (get from https://console.groq.com/keys — create with "No expiration")
OPENAI_API_KEY=YOUR_GROQ_API_KEY_HERE

# Qdrant
QDRANT_URL=http://localhost:6333
